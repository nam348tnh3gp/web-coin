# Server
PORT=3000
NODE_ENV=production

# Database
DATABASE_PATH=./webcoin.db

# Blockchain
DIFFICULTY=3
MINING_REWARD=100
MIN_REWARD=10
MAX_REWARD=200

# HMAC Security
HMAC_SECRET=7f8a3b9c2d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a
HMAC_SALT_ROTATION_INTERVAL=86400000
HMAC_MAX_AGE=300000
API_KEY_EXPIRY=604800000

# Salt Configuration
SALT_LENGTH=16
BLOCK_SALT_LENGTH=8

# PoW Configuration
MIN_DIFFICULTY=1
MAX_DIFFICULTY=10
HASH_RATE_SAMPLES=100

# Security
JWT_SECRET=your-very-strong-secret-change-this-please-use-long-key
SESSION_SECRET=another-secret-for-cookies-make-it-strong-too
CORS_ORIGIN=https://webcoin-1n9d.onrender.com
TRUST_PROXY=true

# Logging
LOG_LEVEL=info
